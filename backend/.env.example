# Valores soportados: development, testing, staging, production
APP_ENV=development
DB_HOST=localhost
DB_PORT=5432
DB_NAME=siged_pnp
DB_USER=postgres
DB_PASSWORD=
DB_CONNECT_TIMEOUT_SECONDS=5
DB_STATEMENT_TIMEOUT_MS=15000
DB_LOCK_TIMEOUT_MS=3000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=10000
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_APPLICATION_NAME=siged-pnp-backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Genera un valor unico de al menos 32 caracteres para entornos persistentes.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
PASSWORD_HASH_ITERATIONS=390000
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID
CORS_ALLOW_CREDENTIALS=true
# Habilitar solo de forma temporal para crear el primer administrador.
ALLOW_BOOTSTRAP_ADMIN=false
# Solo habilitar en development/testing. En staging/production el backend aborta si esta en true.
ENABLE_API_DOCS=true
EVENTOS_DEFAULT_LIMIT=5000
EVENTOS_MAX_LIMIT=5000
HEATMAP_DEFAULT_LIMIT=10000
HEATMAP_MAX_LIMIT=10000
REQUEST_SLOW_LOG_MS=800
QUERY_SLOW_LOG_MS=250
OPERATION_SLOW_LOG_MS=400
# Por defecto se resuelve a ../salida_geojson desde backend/.
# No publiques capas territoriales reales en este repositorio.
# GEOJSON_LAYERS_DIR=../salida_geojson
# Usar solo como contingencia temporal para forzar runtime territorial desde GeoJSON.
GEO_LAYERS_FORCE_LEGACY=false
